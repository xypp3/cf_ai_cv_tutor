{
  "manifest_version": 2,
  "name": "CV Tailor",
  "version": "0.1.0",
  "description": "Scrape a job description, compare against your CV, and surface quick tailoring suggestions.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "Analyze this job",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cv-tailor@example.com"
    }
  }
}
